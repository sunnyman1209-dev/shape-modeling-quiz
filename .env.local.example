# 이 파일을 복사해서 .env.local 로 저장한 뒤 값만 채우세요.
# ( .env.local 은 git 에 올리지 마세요 )

# ① 테이블 생성용 — Database → Connection string → URI (비밀번호 포함)
DATABASE_URL=postgresql://postgres.xxxxx:[YOUR-DB-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# ② API 배포용 — Project Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
